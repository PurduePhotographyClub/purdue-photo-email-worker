{
  "name": "purdue-photography-club-email-worker",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "dev": "wrangler dev --port 8791",
    "typecheck": "tsc --noEmit",
    "doctor": "npx react-doctor@latest --verbose --no-score --yes",
    "verify": "npm run typecheck && npm run build && npm run doctor"
  },
  "reactDoctor": {
    "ignore": {
      "files": ["dist/**", ".wrangler/**"]
    }
  },
  "dependencies": {
    "postal-mime": "^2.6.0",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260621.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.95.0"
  }
}
